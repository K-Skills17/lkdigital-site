# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://your-evolution-instance.com
EVOLUTION_API_KEY=your-api-key
EVOLUTION_INSTANCE=your-instance-name

# Google Tag Manager (optional — only renders if set)
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Demo page tenant — swap this to point /demo at a different trained tenant
NEXT_PUBLIC_DEMO_TENANT_ID=your-demo-tenant-uuid-here

# RAIO-X Scorecard Funnel
TELEGRAM_BOT_TOKEN=           # @Lkdigital_bot token
NOTIFY_KOMANDO_CHAT_ID=       # Send /start to @Lkdigital_bot, then check getUpdates
NOTIFY_MARCOS_CHAT_ID=        # Marcos must also send /start to @Lkdigital_bot

# RAIO-X public config
NEXT_PUBLIC_LK_BOOKING_URL=   # LK Digital booking/cal link
NEXT_PUBLIC_MARCOS_BOOKING_URL=  # Biodonte booking link (leave empty to fall back to WA)
NEXT_PUBLIC_MARCOS_WA_NUMBER=    # Marcos WhatsApp intl format e.g. 5511999990000
